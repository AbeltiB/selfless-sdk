{
  "name": "selfless-sdk",
  "version": "1.0.0",
  "publishConfig": {"access": "public"},
  "description": "SelfLess Platform shared SDK — types, events, validators, utils",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AbeltiB/selfless-sdk.git"
  },
  "keywords": [
    "selfless",
    "sdk",
    "queue",
    "service"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "files": [
    "dist"
  ],
  "dependencies": {
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.7.3"
  }
}
